# Local development defaults (loopback mode)
# Copy to .env and adjust as needed

PUBLIC_URL=http://localhost:3000
PORT=3000

# JWT_SECRET is auto-generated if not set (sessions won't survive restarts)
# Set a stable value for local dev so sessions survive server restarts
JWT_SECRET=flint-local-dev-secret-do-not-use-in-production

# Not needed in loopback mode — only required for production
# OAUTH_PRIVATE_KEY=...
